// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  VENDOR
  BUYER
}

enum AuthProvider {
  EMAIL // Email/magic link
  GOOGLE // Google OAuth
}

enum Gender {
  MALE
  FEMALE
  PREFER_NOT_TO_SAY
}

enum VendorTier {
  TIER_0 // Unverified
  TIER_1 // Basic verified
  TIER_2 // Business verified
  TIER_3 // Elite seller
  TIER_4 // Premium verified
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationType {
  NIN // National Identification Number
  CAC // Corporate Affairs Commission
  SMEDAN // Small & Medium Enterprises Development Agency
  ADDRESS // Address verification
}

enum BusinessType {
  // For CAC
  LIMITED_LIABILITY
  BUSINESS_NAME
  INCORPORATED_TRUSTEES

  // For SMEDAN
  SOLE_PROPRIETOR
  PARTNERSHIP
  COOPERATIVE
}

enum PaymentModel {
  FULL_PAYMENT
  PART_PAYMENT
  PAY_ON_DELIVERY
  INSTALLMENT
}

enum PrimaryContactMethod {
  WHATSAPP
  INSTAGRAM
  TIKTOK
  FACEBOOK
  PHONE_CALL
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  READY_FOR_DISPATCH
  SHIPPED
  DELIVERED
  COMPLETED
  REFUND_REQUESTED
  REFUND_IN_PROGRESS
  REFUNDED
  RESOLVED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PROOF_SUBMITTED
  PAID
  REFUNDED
}

enum RefundStatus {
  NONE
  REQUESTED
  IN_PROGRESS
  REFUNDED
  RESOLVED
}

enum DeliveryMethod {
  PICKUP
  DISPATCH
  WAYBILL
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RefundPolicyType {
  NO_REFUNDS // No refunds accepted
  FULL_REFUND // Full refund within duration
  PARTIAL_REFUND // Partial refund (e.g., minus shipping)
  EXCHANGE_ONLY // Product exchange only
  STORE_CREDIT // Store credit instead of cash
  CASE_BY_CASE // Evaluated individually
}

enum ProductMediaType {
  IMAGE
  VIDEO
}

// ============================================
// USER MODEL
// ============================================

model User {
  id String @id @default(cuid())

  // Identity
  name       String?
  email      String  @unique
  avatar_url String?

  // Authentication
  auth_provider AuthProvider @default(EMAIL)
  google_id     String?      @unique // Google OAuth ID

  // Email verification
  email_verified Boolean @default(false)

  // Role & Status
  role      UserRole @default(VENDOR)
  is_active Boolean  @default(true)

  // Session tracking
  last_login_at DateTime?

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  otp_codes      OtpCode[]
  magic_links    MagicLink[]
  vendor_profile VendorProfile[]
  buyer_profile  BuyerProfile[]
  admin_profile  AdminProfile[]
  admin_actions  AdminActivityLog[]
  orders   Order[]

  @@index([email])
  @@index([google_id])
  @@map("users")
}

// ============================================
// OTP CODES (email verification)
// ============================================

model OtpCode {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  code       String
  attempts   Int      @default(0)
  expires_at DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([code])
  @@map("otp_codes")
}

// ============================================
// MAGIC LINKS (passwordless login)
// ============================================

model MagicLink {
  id         String    @id @default(cuid())
  user_id    String
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token      String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([user_id])
  @@index([token])
  @@map("magic_links")
}

// ============================================
// RATE LIMITING (prevent abuse)
// ============================================

model RateLimit {
  id     String @id @default(cuid())
  key    String //email or IP address
  action String // "otp_send", "magic_link_send", "login_attempt"

  count    Int      @default(1)
  reset_at DateTime

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([key, action])
  @@map("rate_limits")
}

// ============================================
// VENDOR PROFILE (EXTENDED)
// ============================================

model VendorProfile {
  id      String @id @default(cuid())
  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // ========== STEP 1: PERSONAL INFORMATION ==========
  first_name    String?
  middle_name   String?
  last_name     String?
  gender        Gender?
  date_of_birth DateTime?
  phone_number  String?

  // ========== STEP 2: BUSINESS INFORMATION ==========

  // Basic Details
  business_name        String?
  business_description String? @db.Text
  slug                 String? @unique
  profile_photo_url    String?

  // Location
  country        String  @default("Nigeria")
  state          String?
  city           String?
  street_address String?
  landmark       String?
  latitude       Float?
  longitude      Float?

  // Categorization
  primary_category String?
  subcategories    String[] @default([])

  // Make payment Information multiple and have a primary payment info
  // Payment Information
  bank_name      String?
  account_number String?
  account_name   String?
  payment_models PaymentModel[] @default([])

  //Refund Policy
  refund_policy_type   RefundPolicyType @default(NO_REFUNDS)
  refund_duration_days Int? // e.g., 7, 14, 30
  refund_conditions    String[]         @default([]) // Array of conditions
  refund_custom_notes  String?          @db.Text // Additional vendor notes

  // Social Media
  instagram_handle String?
  tiktok_handle    String?
  facebook_url     String?
  whatsapp_number  String?
  primary_contact  PrimaryContactMethod?

  // ========== VERIFICATION & TIERING ==========

  // Tier Status
  current_tier        VendorTier @default(TIER_0)
  verification_points Int        @default(0)

  // Profile Completeness
  personal_info_complete Boolean @default(false)
  business_info_complete Boolean @default(false)
  profile_completeness   Int     @default(0) // 0-100%

  // ========== CALCULATED METRICS ==========
  // Performance (system-calculated from order data)
  total_orders        Int   @default(0)
  successful_orders   Int   @default(0)
  fulfillment_rate          Float @default(0)
  refund_rate               Float @default(0)
  on_time_delivery_rate     Float @default(0)
  avg_response_time_minutes Float @default(0)

  // Customer Feedback (derived from approved review ratings)
  review_count                 Int   @default(0)
  average_rating               Float @default(0)
  avg_delivery_rating          Float @default(0)
  avg_response_rating          Float @default(0)
  customer_satisfaction_rating Float @default(0)

  // Status
  profile_status String @default("active") // active, inactive, suspended

  // Timestamps
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  last_order_at DateTime?

  // Relations
  verifications VendorVerification[]
  products      Product[]
  orders  Order[]
  reviews       Review[]
  posts         VendorPost[]

  @@index([slug])
  @@index([state, city])
  @@index([current_tier])
  @@index([verification_points])
  @@index([total_orders])
  @@index([created_at])
  //@@fulltext([business_name, business_description])
  @@map("vendor_profiles")
}

// ============================================
// VENDOR VERIFICATIONS
// ============================================

model VendorVerification {
  id        String        @id @default(cuid())
  vendor_id String
  vendor    VendorProfile @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  // Verification Details
  type   VerificationType
  status VerificationStatus @default(PENDING)

  // Points awarded (used for tier calculation)
  points_value Int @default(0)

  // NIN Verification Fields
  nin_number              String? // 11 digits
  nin_full_name           String?
  govt_id_front_url       String?
  govt_id_front_public_id String? // Cloudinary public ID
  govt_id_back_url        String?
  govt_id_back_public_id  String? // Cloudinary public ID

  // CAC Verification Fields
  cac_rc_number             String?
  cac_company_type          BusinessType?
  cac_certificate_url       String?
  cac_certificate_public_id String? // Cloudinary public ID

  // SMEDAN Verification Fields
  smedan_suin                  String?
  smedan_business_type         BusinessType?
  smedan_certificate_url       String?
  smedan_certificate_public_id String? // Cloudinary public ID

  // Address Verification Fields
  address_document_url       String? // Utility bill
  address_document_public_id String? // Cloudinary public ID

  // Admin Review
  reviewed_by      String? // Admin user ID
  reviewed_at      DateTime?
  rejection_reason String?   @db.Text
  admin_notes      String?   @db.Text

  // Timestamps
  submitted_at DateTime  @default(now())
  approved_at  DateTime?
  updated_at   DateTime  @updatedAt

  @@index([vendor_id])
  @@index([type, status])
  @@index([status])
  @@map("vendor_verifications")
}

// ============================================
// BUSINESS CATEGORIES (Predefined)
// ============================================

model BusinessCategory {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  icon_url    String?

  // Subcategories stored as JSON array for flexibility
  subcategories String[] @default([])

  // Ordering
  display_order Int     @default(0)
  is_active     Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([slug])
  @@index([is_active])
  @@map("business_categories")
}

// ============================================
// BUYER PROFILE
// ============================================

model BuyerProfile {
  id      String @id @default(cuid())
  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  name String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  reviews Review[]

  @@map("buyer_profiles")
}

// ============================================
// PRODUCTS
// ============================================

model Product {
  id        String        @id @default(cuid())
  vendor_id String
  vendor    VendorProfile @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  name                String
  description         String?     @db.Text
  price               Float
  category            String
  stock_status        StockStatus @default(IN_STOCK)
  stock_quantity      Int?
  track_inventory     Boolean     @default(false)
  low_stock_threshold Int?

  // Media
  media     ProductMedia[]
  video_url String?

  // Timestamps
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  // Relations
  order_items OrderItem[]

  @@index([vendor_id])
  @@index([category])
  @@index([created_at])
  @@index([deleted_at])
  @@index([vendor_id, created_at])
  //@@fulltext([name, description])
  @@map("products")
}

model ProductMedia {
  id         String  @id @default(cuid())
  product_id String
  product    Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  media_url  String
  public_id  String? // Cloudinary public ID for deletion
  media_type ProductMediaType
  is_primary Boolean          @default(false)
  position   Int              @default(0)

  created_at DateTime @default(now())

  @@index([product_id])
  @@map("product_media")
}

// ============================================
// VENDOR POSTS (Social Feed)
// ============================================

model VendorPost {
  id        String        @id @default(cuid())
  vendor_id String
  vendor    VendorProfile @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  caption    String? @db.Text
  media_type String // 'image' or 'video'
  media_url  String
  public_id  String? // Cloudinary public ID

  // Engagement
  view_count Int @default(0)
  like_count Int @default(0)

  // Timestamps
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@index([vendor_id])
  @@index([created_at])
  @@index([deleted_at])
  @@map("vendor_posts")
}

// ============================================
// TRANSACTIONS
// ============================================

model Order {
  id             String @id @default(cuid())
  reference      String @unique // SC-2025-00047
  tracking_token String @unique // 12-char random alphanumeric

  // Parties
  vendor_id   String
  vendor      VendorProfile @relation(fields: [vendor_id], references: [id])
  buyer_id    String?
  buyer       User?         @relation(fields: [buyer_id], references: [id])
  buyer_email String?

  // Expected Delivery Window
  delivery_method         DeliveryMethod
  expected_delivery_start DateTime?
  expected_delivery_end   DateTime?
  actual_delivery_date    DateTime?

  // Items
  items OrderItem[]

  // Financials
  subtotal        Decimal  @db.Decimal(10, 2)
  delivery_fee    Decimal? @db.Decimal(10, 2)
  discount_amount Decimal? @db.Decimal(10, 2)
  total_amount    Decimal  @db.Decimal(10, 2)
  currency        String   @default("NGN")

  // Payment
  payment_status            PaymentStatus @default(UNPAID)
  payment_proof_url         String?
  payment_proof_submitted_at DateTime?
  payment_confirmed_at      DateTime?
  payment_notes             String?

  // Status
  status OrderStatus @default(PENDING)

  // Status Timestamps
  confirmed_at          DateTime?
  in_progress_at        DateTime?
  ready_for_dispatch_at DateTime?
  shipped_at            DateTime?
  delivered_at          DateTime?
  completed_at          DateTime?
  cancelled_at          DateTime?
  refund_initiated_at   DateTime?
  refunded_at           DateTime?
  resolved_at           DateTime?

  // Refund
  refund_status       RefundStatus @default(NONE)
  refund_reason       String?
  refund_amount       Decimal?     @db.Decimal(10, 2)
  refund_vendor_notes String?

  // Auto-close (48h after DELIVERED)
  auto_close_at DateTime?

  // Cancellation
  cancelled_by        String?
  cancellation_reason String?

  // Notes
  vendor_notes String?
  order_notes  String?

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  status_history OrderStatusHistory[]
  review         Review?

  @@index([vendor_id, status])
  @@index([tracking_token])
  @@index([reference])
  @@index([buyer_email])
  @@index([refund_status])
  @@index([payment_status])
  @@index([created_at])
  @@map("orders")
}

model OrderItem {
  id             String      @id @default(cuid())
  order_id String
  order    Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  // Product reference (optional — null for manual items)
  product_id String?
  product    Product? @relation(fields: [product_id], references: [id])

  // Snapshot of product at time of transaction
  item_name      String
  item_price     Decimal @db.Decimal(10, 2)
  quantity       Int     @default(1)
  subtotal       Decimal @db.Decimal(10, 2)
  item_image_url String?
  description    String?  @map("variant")

  // Stock audit trail
  stock_deducted Int @default(0)
  stock_restored Int @default(0)

  @@index([order_id])
  @@index([product_id])
  @@map("order_items")
}

model OrderStatusHistory {
  id             String      @id @default(cuid())
  order_id String
  order    Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  from_status OrderStatus?
  to_status   OrderStatus
  changed_by  String
  note        String?

  created_at DateTime @default(now())

  @@index([order_id])
  @@map("order_status_history")
}

// ============================================
// REVIEWS
// ============================================

model Review {
  id String @id @default(cuid())

  // Transaction
  order_id String      @unique
  order    Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  // Vendor
  vendor_id String
  vendor    VendorProfile @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  // Buyer
  buyer_id   String?
  buyer      BuyerProfile? @relation(fields: [buyer_id], references: [id])
  buyer_name String?

  // Review Content
  overall_rating     Int // 1-5 stars
  delivery_rating    Int?
  response_rating    Int?
  satisfaction_rating Int?
  review_text        String? @db.Text

  // Moderation
  moderation_status ModerationStatus @default(PENDING)
  approved_by       String?
  approved_at       DateTime?
  rejection_reason  String?

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([vendor_id])
  @@index([overall_rating])
  @@index([moderation_status])
  @@index([created_at])
  @@map("reviews")
}

// ============================================
// ADMIN PROFILE
// ============================================

model AdminProfile {
  id      String @id @default(cuid())
  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Personal information
  first_name    String?
  middle_name   String?
  last_name     String?
  gender        Gender?
  date_of_birth DateTime?
  phone_number  String?

  // Admin-specific metadata
  department String? // e.g. "Verification Team", "User Management"
  role_title String? // e.g. "Senior Admin", "Support Admin"

  // Profile photo
  profile_photo_url       String?
  profile_photo_public_id String?

  // Completeness flag — true when first_name, last_name, and phone_number are all set
  profile_complete Boolean @default(false)

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@map("admin_profiles")
}

// ============================================
// ADMIN OPERATIONS
// ============================================

model AdminActivityLog {
  id       String @id @default(cuid())
  admin_id String
  admin    User   @relation(fields: [admin_id], references: [id])

  action_type String // "nin_approved", "cac_rejected", etc.
  target_type String // "vendor_verification", "review", etc.
  target_id   String // ID of the affected resource
  notes       String? @db.Text

  // Store snapshot of data before change (for audit)
  before_data Json?
  after_data  Json?

  created_at DateTime @default(now())

  @@index([admin_id])
  @@index([action_type])
  @@index([target_type, target_id])
  @@index([created_at])
  @@map("admin_activity_logs")
}
