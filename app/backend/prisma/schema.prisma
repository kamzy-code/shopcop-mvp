// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// ============================================
// ENUMS
// ============================================

enum UserRole {
  ADMIN
  VENDOR
  BUYER
}

enum AuthProvider {
  EMAIL      // Email/magic link
  GOOGLE     // Google OAuth
}

// ============================================
// USER MODEL
// ============================================

model User {
  id         String   @id @default(cuid())
  
  // Identity
  email      String   @unique
  name       String?
  avatar_url String?
  
  // Authentication
  auth_provider AuthProvider @default(EMAIL)
  google_id     String?      @unique // Google OAuth ID
  
  // Email verification
  email_verified Boolean  @default(false)
  
  // OTP fields (for email verification)
  otp_code       String?
  otp_expires_at DateTime?
  otp_attempts   Int      @default(0)
  otp_last_sent_at DateTime?
  
  // Magic link fields (for passwordless login)
  magic_token    String?   @unique
  magic_expires_at DateTime?
  
  // Role & Status
  role       UserRole @default(VENDOR)
  is_active  Boolean  @default(true)
  
  // Session tracking
  last_login_at DateTime?
  
  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  // Relations (we'll add these later)
  // vendor_profile VendorProfile?
  // admin_actions  AdminActivityLog[]
  
  @@index([email])
  @@index([google_id])
  @@index([magic_token])
  @@map("users")
}

// ============================================
// RATE LIMITING (prevent abuse)
// ============================================

model RateLimit {
  id       String   @id @default(cuid())
  key      String   @unique // email or IP address
  action   String   // "otp_send", "magic_link_send", "login_attempt"
  
  count    Int      @default(1)
  reset_at DateTime
  
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  @@index([key, action])
  @@map("rate_limits")
}