{
  "name": "shopcop",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd app/backend && npm run dev",
    "dev:frontend": "cd app/frontend && npm run dev",
    "build:frontend": "cd app/frontend && npm run build",
    "build:backend": "cd app/backend && npm run build",
    "start:frontend": "cd app/frontend && npm run start",
    "start:backend": "cd app/backend && npm run start",
    "prisma:generate": "cd app/backend && npm run prisma:generate",
    "prisma:migrate": "cd app/backend && npm run prisma:migrate",
    "seed": "cd app/backend && npm run seed",
    "lint": "cd app/backend && npm run lint && cd ../frontend && npm run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3"
  }
}
